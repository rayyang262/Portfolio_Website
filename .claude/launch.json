{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Site (Python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080", "--directory", "PortWebsite"],
      "port": 8080
    },
    {
      "name": "Static Site (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "PortWebsite", "--no-clipboard"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
